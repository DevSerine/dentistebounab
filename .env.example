# Required: public site URL used for metadata and canonical links
NEXT_PUBLIC_SITE_URL=https://dentistebounab.netlify.app

# Option A — EmailJS (recommended if you already have an EmailJS account)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Option B — Web3Forms (free, https://web3forms.com)
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
